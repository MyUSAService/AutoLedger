# --- Database ---
DATABASE_URL="postgresql://portal:portal@localhost:5432/statement_portal"
# Direct/session-pooler connection for schema changes (db push / migrations).
# Locally this is the same as DATABASE_URL; on Supabase use the session pooler (port 5432).
DIRECT_DATABASE_URL="postgresql://portal:portal@localhost:5432/statement_portal"

# --- Anthropic API (extraction + classification) ---
# Never commit the real key. Provided at deploy time.
ANTHROPIC_API_KEY=""
# Model used for PDF extraction (vision) and classification
ANTHROPIC_MODEL="claude-sonnet-4-5"

# --- File storage ---
# "local" (dev) | "netlify_blobs" (Netlify deploys) | "s3" (R2 / any S3-compatible)
STORAGE_DRIVER="local"
STORAGE_LOCAL_PATH="./storage"
S3_ENDPOINT=""            # e.g. https://<accountid>.r2.cloudflarestorage.com
S3_BUCKET="statement-portal"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_REGION="auto"

# --- Email (Resend) ---
# Empty key = emails are logged to the console (dev mode)
RESEND_API_KEY=""
EMAIL_FROM="Altemore <noreply@altemore.com>"
APP_URL="http://localhost:3000"

# --- Pipeline configuration ---
LARGE_PURCHASE_THRESHOLD_CENTS="250000"   # $2,500 default — potential fixed asset
EXTRACTION_MAX_PAGES_PER_CHUNK="8"
